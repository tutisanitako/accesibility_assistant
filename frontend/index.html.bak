      'padding:14px 16px',
      'margin-top:10px',
      'animation:slideUp 0.3s ease',
      'display:flex',
      'align-items:flex-start',
      'gap:12px',
    ].join(';');

    if (step.type === 'walking') {
      // Only show walking steps that are meaningful (>50m)
      const dist = step.distance || '';
      const distM = parseFloat(dist);
      // Skip tiny walking steps at end (street addresses)
      if (dist.includes('კმ') || distM > 50 || isNaN(distM)) {
        card.innerHTML = `
          <span style="font-size:22px;flex-shrink:0">🚶</span>
          <div>
            <div style="font-size:14px;font-weight:600;color:var(--text)">
              ფეხით ${dist}
            </div>
            <div style="font-size:12px;color:var(--text3);margin-top:2px">
              ${step.duration || ''}
            </div>
          </div>`;
        resultsEl.appendChild(card);
      }
    } else if (step.type === 'transit') {
      card.style.borderLeft = '4px solid var(--accent2)';
      card.innerHTML = `
        <span style="font-size:26px;flex-shrink:0">🚌</span>
        <div style="flex:1">
          <div style="font-size:18px;font-weight:700;color:var(--accent2)">
            ${step.line_name}-ე მარშრუტი
          </div>
          <div style="font-size:13px;color:var(--text);margin-top:5px">
            <b>${step.departure_time || ''}</b>
            ${step.depart_stop ? '· ' + step.depart_stop : ''}
          </div>
          <div style="font-size:12px;color:var(--text3);margin-top:3px">
            ${step.num_stops || 0} გაჩერება
            ${step.arrive_stop ? '→ ' + step.arrive_stop : ''}
            ${step.arrival_time ? '· (' + step.arrival_time + ')' : ''}
          </div>
          <div style="font-size:11px;color:var(--text3);margin-top:2px">
            ${step.duration || ''}
          </div>
        </div>`;
      resultsEl.appendChild(card);
    }
  });
}

// ── Bus offer ─────────────────────────────────────────────────────────────────
let currentVenueOffer = '';
function showBusOffer(venue) {
  currentVenueOffer = venue;
  document.getElementById('bus-offer-text').textContent = `გსურთ ${venue}-სკენ მიმავალი ავტობუსები?`;
  busOffer.classList.add('visible');
}
function hideBusOffer() { busOffer.classList.remove('visible'); currentVenueOffer = ''; }
document.getElementById('bus-offer-no').addEventListener('click', hideBusOffer);
// ── PATCH for frontend/index.html ──────────────────────────────────────────
// Replace the entire bus-offer "yes" button handler with this:

document.getElementById('bus-offer-yes').addEventListener('click', async () => {
  const venue = currentVenueOffer;
  hideBusOffer();
  setStatus('მარშრუტს ვეძებ...', 'active');
  resultsEl.innerHTML = '';

  const doJourney = async (lat, lng) => {
    try {
      const locParam = (lat && lng) ? `&lat=${lat}&lng=${lng}` : '';
      const res = await apiFetch(`/journey?q=${encodeURIComponent(venue)}${locParam}`);
      const data = await res.json();
      if (!res.ok) {
        setResponse(data.detail || 'ავტობუსი ვერ მოიძებნა.');
      } else if (data.directions) {
        // Google Maps directions available
        const steps = (data.directions.steps || []).filter(s => s.type === 'transit');
        const total = data.directions.total_duration || '';
        let msg = steps.length > 0
          ? `${venue}-ში სასვლელად: ${steps[0].line_name}-ე ავტობუსი ${steps[0].departure_time}-ზე. სულ ${total}.`
          : `${venue}-ში მარშრუტი ნაპოვნია. სულ ${total}.`;
        setResponse(msg);
        renderDirections(data.directions);
        await speak(msg);
      } else {
        setResponse(data.response_georgian);
        renderJourneyCards(data.stops || []);
        await speak(data.response_georgian);
      }
    } catch { setStatus('შეცდომა', 'error'); }
    setStatus('მზადაა ✓', 'ok');
  };

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      pos => doJourney(pos.coords.latitude, pos.coords.longitude),
      ()  => doJourney(null, null)
    );
  } else {
    doJourney(null, null);
  }
});

// ── Also add renderDirections function if not already present ──────────────
function renderDirections(directions) {
  resultsEl.innerHTML = '';
  const hdr = document.createElement('div');
  hdr.className = 'section-hdr';
  hdr.textContent = `🗺️ მარშრუტი (${directions.total_duration || ''})`;
  resultsEl.appendChild(hdr);

  if (directions.departure_time && directions.arrival_time) {
    const info = document.createElement('div');
    info.style.cssText = 'padding:8px 2px;font-size:13px;color:var(--text2)';
    info.textContent = `${directions.departure_time}-ზე გამგზავრება → ${directions.arrival_time}-ზე ჩამოსვლა`;
    resultsEl.appendChild(info);
  }

  (directions.steps || []).forEach(step => {
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 16px;margin-top:10px;animation:slideUp 0.3s ease';
    if (step.type === 'walking') {
      card.innerHTML = `
        <div style="display:flex;align-items:center;gap:12px">
          <span style="font-size:24px">🚶</span>
          <div>
            <div style="font-size:14px;font-weight:600;color:var(--text)">ფეხით ${step.distance || ''}</div>
            <div style="font-size:12px;color:var(--text3);margin-top:2px">${step.duration || ''} · ${step.instructions || ''}</div>
          </div>
        </div>`;
    } else if (step.type === 'transit') {
      card.style.borderLeft = '4px solid var(--accent2)';
      card.innerHTML = `
        <div style="display:flex;align-items:center;gap:12px">
          <span style="font-size:24px">🚌</span>
          <div style="flex:1">
            <div style="font-size:17px;font-weight:700;color:var(--accent2)">${step.line_name}-ე მარშრუტი</div>
            <div style="font-size:13px;color:var(--text);margin-top:4px">
              <b>${step.departure_time}</b> · ${step.depart_stop}
            </div>
            <div style="font-size:12px;color:var(--text3);margin-top:2px">
              ${step.num_stops} გაჩერება → ${step.arrive_stop}
              ${step.arrival_time ? ` (${step.arrival_time})` : ''}
            </div>
          </div>
        </div>`;
    }
    resultsEl.appendChild(card);
  });
}

// ── Description modal ─────────────────────────────────────────────────────────
document.getElementById('desc-close').addEventListener('click', () => {
  document.getElementById('desc-modal').classList.remove('visible');
});

function showDescription(name, venue, description) {
  document.getElementById('desc-name').textContent = name;
  document.getElementById('desc-venue').textContent = venue && venue !== 'N/A' ? `📍 ${venue}` : '';
  const body = document.getElementById('desc-body');
  if (description && description.trim()) {
    body.textContent = description;
  } else {
    body.textContent = 'აღწერა არ არის ხელმისაწვდომი.';
  }
  document.getElementById('desc-modal').classList.add('visible');
}

// ── Render ────────────────────────────────────────────────────────────────────
const resultsEl = document.getElementById('results');
const busOffer  = document.getElementById('bus-offer');
const audioEl   = document.getElementById('response-audio');

function renderResults({ intent, results }) {
  resultsEl.innerHTML = '';
  if (!results?.length) return;

  if (intent === 'concert_search') {
    const hdr = document.createElement('div');
    hdr.className = 'section-hdr';
    hdr.textContent = `🎭 ნაპოვნი ღონისძიებები (${results.length})`;
    resultsEl.appendChild(hdr);
    results.forEach(c => resultsEl.appendChild(makeConcertCard(c)));

  } else if (intent === 'bus_search') {
    const hdr = document.createElement('div');
    hdr.className = 'section-hdr';
    hdr.textContent = '🚌 გაჩერებები და გრაფიკი';
    resultsEl.appendChild(hdr);
    results.forEach(stop => resultsEl.appendChild(makeBusCard(stop)));

  } else if (intent === 'journey_search') {
    renderJourneyCards(results);
  }
}

function makeConcertCard(c) {
  const isSoldOut = c.price === 'გაყიდულია';
  const isFree    = c.price === 'უფასო';
  const priceClass = isSoldOut ? 'price-sold' : isFree ? 'price-free' : 'price-paid';
  const priceLabel = isSoldOut ? '🔴 გაყიდულია' : isFree ? '🟢 უფასო' : `💰 ${c.price}`;

  const cat = c.category || 'კონცერტი';
  const catClass = cat === 'თეატრი' ? 'cat-theatre' : cat === 'ოპერა' ? 'cat-opera' : 'cat-concert';
  const catIcon  = cat === 'თეატრი' ? '🎭' : cat === 'ოპერა' ? '🎤' : '🎵';

  const card = document.createElement('article');
  card.className = 'concert-card';
  card.innerHTML = `
    <div class="concert-card-top">
      <div class="concert-name">${c.name}<span class="cat-badge ${catClass}">${catIcon} ${cat}</span></div>
      <div class="concert-venue-line">📍 ${c.venue !== 'N/A' ? c.venue : 'ადგილი უცნობია'}</div>
    </div>
    <div class="concert-card-meta">
      <div class="meta-cell"><div class="meta-cell-label">📅 თარიღი</div><div class="meta-cell-value">${c.date}</div></div>
      <div class="meta-cell"><div class="meta-cell-label">🕐 დრო</div><div class="meta-cell-value">${c.time !== 'N/A' ? c.time : '—'}</div></div>
    </div>
    <div class="concert-card-bottom">
      <span class="price-badge ${priceClass}">${priceLabel}</span>
      <div style="display:flex;gap:8px;align-items:center">
        ${c.description ? `<button class="desc-btn" data-name="${encodeURIComponent(c.name)}" data-venue="${encodeURIComponent(c.venue)}" data-desc="${encodeURIComponent(c.description)}">📖 აღწერა</button>` : ''}
        ${c.url !== 'N/A' && !isSoldOut ? `<a class="ticket-btn" href="${c.url}" target="_blank" rel="noopener">ბილეთი →</a>` : ''}
      </div>
    </div>
  `;
  // Attach description button handler
  const descBtn = card.querySelector('.desc-btn');
  if (descBtn) {
    descBtn.addEventListener('click', () => {
      showDescription(
        decodeURIComponent(descBtn.dataset.name),
        decodeURIComponent(descBtn.dataset.venue),
        decodeURIComponent(descBtn.dataset.desc),
      );
    });
  }
  return card;
}

ffunction makeBusCard(stop, distanceM) {
  const now = new Date();
  const nowMins = now.getHours() * 60 + now.getMinutes();

  const stopName = (stop.name || stop.stop_name || '')
    .replace(/\s*\[\d+\]/g, '')
    .replace(/^მ\/ს\s*["']?/, '')
    .replace(/["']$/, '')
    .trim();

  const dist = distanceM != null ? distanceM : stop.distance_m;
  const distLabel = dist != null
    ? (dist < 1000 ? `${dist}მ` : `${(dist/1000).toFixed(1)}კმ`)
    : '';

  // Walking time: prefer API value, else calculate at 80m/min
  const walkMins = stop.walk_minutes || (dist ? Math.max(1, Math.round(dist / 80)) : null);
  const walkLabel = stop.walk_duration || (walkMins ? `${walkMins} წთ` : '');
  const walkDist  = stop.walk_distance || distLabel;

  const routeNum  = stop.route_number || '';
  const headsign  = stop.headsign || '';
  const depTime   = stop.departure_time || '';  // real departure from Google Maps

  // Build schedule chips
  let schedHTML = '';

  if (depTime) {
    // Google Maps real departure time
    const minsUntil = stop.walk_minutes ? stop.walk_minutes : 0;
    const chipClass = minsUntil <= 5 ? 'time-chip soon' : 'time-chip';
    schedHTML = `
      <div class="bus-times-section">
        <div class="bus-times-label">
          🚌 ${routeNum ? routeNum + '-ე მარშრუტი' : 'ავტობუსი'}
          ${headsign ? `<span style="font-weight:400;color:var(--text3)"> → ${headsign}</span>` : ''}
        </div>
        <div class="times-grid" style="margin-top:8px">
          <span class="${chipClass}">${depTime}</span>
        </div>
        ${walkLabel ? `<div style="font-size:12px;color:var(--text3);margin-top:6px">🚶 ${walkDist} სიარული — ${walkLabel}</div>` : ''}
      </div>`;
  } else {
    // TTC CSV schedule
    const schedule = stop.schedule || [];
    const times = schedule
      .flatMap(h => h.departures.map(m => ({
        h: h.hour, m: parseInt(m),
        total: h.hour * 60 + parseInt(m)
      })))
      .filter(t => t.total > nowMins)
      .slice(0, 5)
      .map(t => ({
        label: `${String(t.h).padStart(2,'0')}:${String(t.m).padStart(2,'0')}`,
        soon: (t.total - nowMins) <= 10
      }));

    if (times.length > 0) {
      schedHTML = `
        <div class="bus-times-section">
          <div class="bus-times-label">შემდეგი ავტობუსები${routeNum ? ' · ' + routeNum + '-ე' : ''}</div>
          <div class="times-grid">
            ${times.map(t => `<span class="time-chip${t.soon?' soon':''}">${t.label}${t.soon?' ⚡':''}</span>`).join('')}
          </div>
          ${walkLabel ? `<div style="font-size:12px;color:var(--text3);margin-top:6px">🚶 ${walkLabel} სიარული</div>` : ''}
        </div>`;
    } else if (schedule.length > 0) {
      schedHTML = `<div class="bus-times-section"><div class="no-more-buses">დღის ბოლო რეისი გავიდა</div></div>`;
    }
    // No schedule at all = no section shown
  }

  const card = document.createElement('article');
  card.className = 'bus-card';
  card.innerHTML = `
    <div class="bus-card-header">
      <div class="bus-stop-name">${stopName}</div>
      ${distLabel ? `<span class="bus-dist-badge">${distLabel}</span>` : ''}
    </div>
    ${schedHTML}`;
  return card;
}

function renderJourneyCards(stops) {
  resultsEl.innerHTML = '';
  const hdr = document.createElement('div');
  hdr.className = 'section-hdr';
  hdr.textContent = '🚌 შესაბამისი მარშრუტები';
  resultsEl.appendChild(hdr);

  const byRoute = {};
  stops.forEach(s => { if (!byRoute[s.route_number]) byRoute[s.route_number] = s; });

  Object.entries(byRoute).forEach(([route, stop]) => {
    const now = new Date();
    const nowMins = now.getHours() * 60 + now.getMinutes();
    const times = (stop.schedule || [])
      .flatMap(h => h.departures.map(m => ({ h: h.hour, m: parseInt(m), total: h.hour*60+parseInt(m) })))
      .filter(t => t.total > nowMins)
      .slice(0, 4)
      .map(t => ({ label: `${String(t.h).padStart(2,'0')}:${String(t.m).padStart(2,'0')}`, mins: t.total - nowMins, soon: (t.total - nowMins) <= 10 }));

    const stopName = (stop.stop_name || '').replace(/\s*\[\d+\]/g, '').replace(/^მ\/ს\s*["']?/, '').replace(/["']$/, '').trim();
    const card = document.createElement('article');
    card.className = 'journey-card';
    card.innerHTML = `
      <div class="journey-route-num">${route}-ე მარშრუტი</div>
      <div class="journey-route-label">📍 ${stopName}</div>
      ${times.length ? `
        <div class="bus-times-label" style="margin-top:8px">შემდეგი ავტობუსები</div>
        <div class="times-grid" style="margin-top:6px">
          ${times.map(t => `<span class="time-chip${t.soon ? ' soon' : ''}">${t.label} <small style="font-size:11px;opacity:0.8">${t.mins}წთ${t.soon ? ' ⚡' : ''}</small></span>`).join('')}
        </div>
      ` : '<div class="no-more-buses" style="margin-top:6px">დღის ბოლო რეისი გავიდა</div>'}
    `;
    resultsEl.appendChild(card);
  });
}

function renderNearestStops(stops) {
  resultsEl.innerHTML = '';
  const hdr = document.createElement('div');
  hdr.className = 'section-hdr';
  hdr.textContent = `📍 ახლომდებარე გაჩერებები (${stops.length})`;
  resultsEl.appendChild(hdr);
  stops.forEach(s => resultsEl.appendChild(makeBusCard(s, s.distance_m)));
}

function renderHomeRouteResults(data) {
  resultsEl.innerHTML = '';

  if (data.direct_routes.length) {
    const hdr = document.createElement('div');
    hdr.className = 'section-hdr';
    hdr.textContent = `✅ პირდაპირი მარშრუტები სახლამდე`;
    resultsEl.appendChild(hdr);
    // Show home stops that have direct routes
    data.home_stops.filter(s => s.serves_current_location).forEach(s => resultsEl.appendChild(makeBusCard(s, s.distance_m)));
  }

  const hdr2 = document.createElement('div');
  hdr2.className = 'section-hdr';
  hdr2.textContent = '🏠 სახლთან ახლოს გაჩერებები';
  resultsEl.appendChild(hdr2);
  data.home_stops.slice(0, 5).forEach(s => resultsEl.appendChild(makeBusCard(s, s.distance_m)));
}

// ── Text input ────────────────────────────────────────────────────────────────
const textInput = document.getElementById('text-input');
const textSend  = document.getElementById('text-send');
textSend.addEventListener('click', () => { const t = textInput.value.trim(); if (t) { processText(t); textInput.value = ''; } });
textInput.addEventListener('keydown', e => { if (e.key === 'Enter') { const t = textInput.value.trim(); if (t) { processText(t); textInput.value = ''; } } });

// ── Helpers ───────────────────────────────────────────────────────────────────
const statusBar    = document.getElementById('status-bar');
const transcriptEl = document.getElementById('transcript');
const responseEl   = document.getElementById('response-text');

function setStatus(msg, cls) { statusBar.textContent = msg; statusBar.className = cls || ''; }
function setTranscript(text) { transcriptEl.textContent = text; transcriptEl.classList.remove('empty'); }
function setResponse(text)   { responseEl.textContent = text;   responseEl.classList.remove('empty'); }
</script>
</body>
</html>