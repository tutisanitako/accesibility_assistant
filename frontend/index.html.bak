  if (dep || arr) {
    const info = document.createElement('div');
    info.style.cssText = 'padding:6px 2px 10px;font-size:13px;color:var(--text2)';
    info.textContent = [dep && `გამგზავრება: ${dep}`, arr && `ჩამოსვლა: ${arr}`]
      .filter(Boolean).join('  →  ');
    resultsEl.appendChild(info);
